# Plexamp Rater Configuration

# Plex Server Connection Details
PLEX_URL=http://localhost:32400
PLEX_TOKEN=YOUR_PLEX_TOKEN_HERE

# Filter Options (optional)
# PLEX_USER=your_plex_username
# PLAYER_NAME=Plexamp

# Notification Settings
REMINDER_SECONDS=20
ONLY_UNRATED=True

# Hotkeys (using python-keyboard format)
# Options: numpad 1, numpad 2, etc., or keyboard shortcuts like ctrl+alt+1
HOTKEY_1=numpad 1
HOTKEY_2=numpad 2
HOTKEY_3=numpad 3
HOTKEY_4=numpad 4
HOTKEY_5=numpad 5
HOTKEY_CLEAR=numpad 0
